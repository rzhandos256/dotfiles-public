alias cls="clear"
alias quit="exit"
alias cat="bat"
alias o="open"
alias c="pbcopy"
alias hh="tldr"
alias t="tree"
alias ac="source ~/files/ac.sh"
alias ca="deactivate"

# zsh
alias zconf="vi ~/.zshrc"
alias zupd="source ~/.zshrc"

# vi
alias vconf="vi ~/.vimrc"

# vi
alias aliass="vi ~/.aliass.zsh"

# skhd
alias skconf="vi ~/.config/skhd/skhdrc"

# tmux
alias tt="tmux new -s "
alias ta="tmux attach -t "
alias tks="tmux kill-server"
alias tls="tmux ls"
alias tconf="vi ~/.tmux.conf"
alias tupd="tmux source-file ~/.tmux.conf"

# env
alias envv="vi ~/.env.zsh"
